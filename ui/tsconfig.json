{
    "compilerOptions": {
        "outDir": "./../dist/app",
        "sourceMap": true,
        "noImplicitAny": true,
        "isolatedModules": true, // for compatibility with esbuild
        "module": "ES2020", // must be ES2020+ for dynamic imports: https://github.com/Microsoft/TypeScript/issues/16675, https://github.com/webpack/webpack/issues/5703#issuecomment-357512412
        "moduleResolution": "node",
        "esModuleInterop": true,
        "target": "es5",
        "jsx": "react",
        "experimentalDecorators": true,
        "noUnusedLocals": true,
        "declaration": false,
        "downlevelIteration": true,
        "baseUrl": ".",
        "paths": {
            // uuid@11 (forced via resolutions for GHSA-w5hq-g745-h8pq) ships type
            // declarations that need TypeScript >= 5.0; use @types/uuid instead
            "uuid": ["node_modules/@types/uuid"]
        },
        "lib": [
            "es2017",
            "dom"
        ]
    },
    "include": [
        "./**/*"
    ],
    "exclude": [
        "e2e",
        "playwright.config.ts"
    ]
}
